-- dept_emp 테이블에서 dept_no로 그룹화하여 부서별 사원 수 조회

-- // 서브 쿼리 B : 부서별 인원수
(SELECT dept_no,count(*) AS dept_no_count 
FROM dept_emp
GROUP BY dept_no);
-- dept_emp 테이블과 departments 테이블에서 dept_no 값이 동일한 행의 dept_name 가져오기.
SELECT B.dept_no, A.dept_name
FROM  (SELECT dept_no,count(*) AS dept_no_count 
	  FROM dept_emp
	  GROUP BY dept_no) B
JOIN departments AS A ON A.dept_no = B.dept_no;