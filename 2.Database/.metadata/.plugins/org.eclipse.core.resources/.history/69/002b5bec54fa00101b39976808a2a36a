
SELECT emp_no, dept_no, from_date FROM dept_emp
WHERE (emp_no, FROM_date) IN(SELECT emp_no, min(from_date) 
						FROM dept_emp
						GROUP BY emp_no);

-- 인라인뷰

SELECT *
FROM (SELECT de.dept_no, avg(s.salary)
	FROM dept_emp de 
	JOIN salaries s ON de.emp_no = s.emp_no 
	GROUP BY dept_no) a;

SELECT *
FROM employees
WHERE rownum <= 3
ORDER BY salary DESC;