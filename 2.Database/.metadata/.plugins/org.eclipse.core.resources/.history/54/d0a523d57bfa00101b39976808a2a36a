SELECT * FROM salaries;

-- 1번

SELECT A.emp_no, B.salary 
FROM employees AS A
LEFT JOIN salaries AS B ON B.salary;


-- 2번
-- 	사원 한명에 대한,
-- 	- 사번
-- 	- 이름
-- 	- 부서정보	
-- //emp_no, first_name -> employees
SELECT * FROM employees;
-- dept_name -> dept_emp
SELECT * FROM dept_emp;
SELECT a.emp_no, a.first_name, B.dept_no
FROM employees AS A
JOIN dept_emp AS B ON A.emp_no = B.emp_no;

SELECT * FROM employees;

-- 3번

-- 사원 한명의 ,
-- 	이름과, 부서명 조회(dept_name)

-- 1. employees 테이블에서 부서번호와 일치하는 부서명을 departments 테이블에서 가져오기
-- 	-> employees 테이블의 사원번호로 dept_emp 테이블과 사원번호가 같은 것에 대한 부서번호를 가져오기
	SELECT A.first_name, B.dept_no
	FROM employees AS A
	JOIN dept_emp AS B ON A.dept_no = B.dept_no;
