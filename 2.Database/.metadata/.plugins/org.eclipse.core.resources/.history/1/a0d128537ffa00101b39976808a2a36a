-- 3번
	SELECT * FROM departments; 		C 테이블


	SELECT A.first_name ,B.dept_no, B.to_date
	FROM employees AS A
	JOIN dept_emp AS B ON A.emp_no = B.emp_no
	WHERE B.to_date = '9999-01-01';									D 테이블

-- 이름에 대한 사원번호를 가져왔다.
-- C 테이블의 부서명과, D 테이블의 이름을 출력한다.(합치기)
-- -> 부서번호가 같은 값에 대해 하나의 테이블로 합친다.

SELECT D.first_name, C.dept_name, D.to_date
	FROM 
	(SELECT A.first_name, B.dept_no
	FROM employees AS A
	JOIN dept_emp AS B ON A.emp_no = B.emp_no) D
	JOIN departments C ON D.dept_no = C.dept_no;
	
